{
  "expo": {
    "name": "MapSale",
    "slug": "mapsale",
    "owner": "minhphuc714",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vinaoffice.mapsale",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MapSale can use location to find items near you.",
        "NSLocationAlwaysUsageDescription": "MapSale can use location to find items near you.",
        "NSCameraUsageDescription": "MapSale needs camera access to take photos.",
        "NSPhotoLibraryUsageDescription": "MapSale needs photo library access to select images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "ed9aa1ee-a5e1-432e-a928-2093fec35a6e"
      }
    }
  }
}
